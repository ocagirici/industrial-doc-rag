# ---- Database (Postgres + pgvector) ----
# Used by the app; docker-compose wires the same values into the db service.
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=ragdb
# Host is 'db' inside docker-compose, 'localhost' when running the app directly.
DATABASE_URL=postgresql+psycopg://rag:rag@db:5432/ragdb

# ---- Embeddings ----
# EMBEDDING_PROVIDER: "local" (sentence-transformers) or "openai"
EMBEDDING_PROVIDER=local
# local default: all-MiniLM-L6-v2 (384 dims)
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# openai option: text-embedding-3-small (1536 dims)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- LLM (answer generation) ----
# LLM_PROVIDER: "anthropic" or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Retrieval / chunking ----
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=5

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
# UI uses this to reach the backend (service name inside compose).
BACKEND_URL=http://localhost:8000
